{
  "name": "Kidrove Event Management",
  "short_name": "Kidrove Events",
  "description": "Discover and book amazing kids' activities and family events in the UAE",
  "theme_color": "#3b82f6",
  "background_color": "#ffffff",
  "display": "standalone",
  "orientation": "portrait-primary",
  "scope": "/",
  "start_url": "/",
  "id": "com.kidrove.events",
  "lang": "en-US",
  "dir": "ltr",
  "categories": [
    "entertainment",
    "lifestyle",
    "kids",
    "family"
  ],
  "icons": [
    {
      "src": "android-chrome-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "android-chrome-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Browse Events",
      "short_name": "Events",
      "description": "Browse all available events",
      "url": "/events",
      "icons": [
        {
          "src": "android-chrome-192x192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "My Bookings",
      "short_name": "Bookings",
      "description": "View your bookings and tickets",
      "url": "/bookings",
      "icons": [
        {
          "src": "android-chrome-192x192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Search Events",
      "short_name": "Search",
      "description": "Search for events",
      "url": "/search",
      "icons": [
        {
          "src": "android-chrome-192x192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+kidrove",
      "url": "/events/%s"
    }
  ],
  "prefer_related_applications": false,
  "edge_side_panel": {
    "preferred_width": 400
  },
  "screenshots": [
    {
      "src": "screenshot-1.png",
      "sizes": "540x720",
      "type": "image/png",
      "platform": "narrow",
      "label": "Event browsing interface"
    },
    {
      "src": "screenshot-2.png",
      "sizes": "720x540",
      "type": "image/png",
      "platform": "wide",
      "label": "Event details and booking"
    }
  ]
}