# ===========================================
# KIDROVE FRONTEND ENVIRONMENT CONFIGURATION
# ===========================================
# Copy this file to .env and fill in your values

# ---- API ----
VITE_API_URL=http://localhost:5001/api
VITE_API_TIMEOUT=30000

# ---- App ----
VITE_APP_NAME=Kidrove
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Event Management and Booking Platform
VITE_APP_URL=http://localhost:3000

# ---- Branding ----
VITE_SITE_ICON=/favicon.ico
VITE_SITE_LOGO=/assets/images/Kidrove-log-new.png

# ---- Auth (token expiry only) ----
VITE_REFRESH_TOKEN_EXPIRY=7d
VITE_ACCESS_TOKEN_EXPIRY=15m

# ---- Stripe (publishable key ONLY) ----
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
VITE_PAYPAL_CLIENT_ID=your_paypal_client_id

# ---- Payment Settings ----
VITE_ENABLE_STRIPE_PAYMENTS=true
VITE_ENABLE_PAYPAL_PAYMENTS=false
VITE_ENABLE_TEST_PAYMENTS=false
VITE_PREFERRED_PAYMENT_METHOD=stripe
VITE_PAYMENT_REGION=AE
VITE_STRIPE_COMPLIANCE_MODE=uae-standard
VITE_PAYMENT_ENVIRONMENT=production
VITE_USE_LIVE_KEYS=true
VITE_FORCE_TEST_MODE=false
VITE_ENABLE_LIVE_KEY_WARNING=true

# ---- Firebase ----
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ---- Cloudinary ----
VITE_UPLOAD_PROVIDER=cloudinary
VITE_MAX_FILE_SIZE=10485760
VITE_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,image/gif
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
VITE_CLOUDINARY_API_KEY=your_cloudinary_api_key
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# ---- Maps ----
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
VITE_MAPBOX_ACCESS_TOKEN=your_mapbox_access_token

# ---- Social Media ----
VITE_FACEBOOK_APP_ID=your_facebook_app_id
VITE_GOOGLE_CLIENT_ID=your_google_client_id
VITE_TWITTER_API_KEY=your_twitter_api_key

# ---- Analytics ----
VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
VITE_FACEBOOK_PIXEL_ID=your_facebook_pixel_id

# ---- Default Author ----
VITE_DEFAULT_AUTHOR_NAME=Kidrove Team
VITE_DEFAULT_AUTHOR_EMAIL=contact@kidrove.com
VITE_DEFAULT_AUTHOR_AVATAR=https://your-domain.com/default-avatar.png
VITE_DEFAULT_AUTHOR_BIO=Your team bio here

# ---- SEO ----
VITE_SITE_NAME=Kidrove - UAE Events & Activities Platform
VITE_SITE_DESCRIPTION=Discover and book amazing events in your area
VITE_SITE_KEYWORDS=events,booking,tickets,entertainment,workshops,conferences
VITE_SITE_AUTHOR=Kidrove Team
VITE_SITE_IMAGE=https://your-domain.com/og-image.jpg
VITE_TWITTER_HANDLE=@your_twitter
VITE_FACEBOOK_PAGE=your_facebook_page
VITE_INSTAGRAM_HANDLE=your_instagram

# ---- Contact ----
VITE_CONTACT_EMAIL=contact@kidrove.com
VITE_SUPPORT_EMAIL=contact@kidrove.com
VITE_CONTACT_PHONE=+971 52 780 9450
VITE_COMPANY_ADDRESS=Level 20, Burj Gate Tower, Downtown Dubai, UAE

# ---- Trust Stats ----
VITE_STATS_YEARS_IN_BUSINESS=7
VITE_STATS_AVERAGE_RATING=4.8
VITE_STATS_TOTAL_BOOKINGS=50000
VITE_STATS_TOTAL_REVIEWS=10000
VITE_STATS_EVENT_VENDORS=100+
VITE_STATS_MONTHLY_BOOKINGS=1K+
VITE_STATS_HAPPY_FAMILIES=5K+
VITE_STATS_ACTIVITIES=500+

# ---- Localization ----
VITE_DEFAULT_LANGUAGE=en
VITE_DEFAULT_CURRENCY=AED
VITE_DEFAULT_TIMEZONE=Asia/Dubai
VITE_SUPPORTED_LANGUAGES=en
VITE_SUPPORTED_CURRENCIES=AED,USD

# ---- Feature Flags ----
VITE_ENABLE_CHAT=false
VITE_ENABLE_NOTIFICATIONS=false
VITE_ENABLE_REVIEWS=true
VITE_ENABLE_FAVORITES=true
VITE_ENABLE_SOCIAL_LOGIN=false
VITE_ENABLE_VENDOR_REGISTRATION=true
VITE_ENABLE_MULTI_LANGUAGE=false
VITE_ENABLE_DARK_MODE=false

# ---- Development ----
# VITE_DEBUG_API=true  # Uncomment for verbose API logging

# ---- Legal ----
VITE_PRIVACY_POLICY_URL=/privacy
VITE_TERMS_OF_SERVICE_URL=/terms
VITE_COOKIE_POLICY_URL=/cookies

# ---- Cache ----
VITE_CACHE_DURATION=300000
VITE_STATIC_CACHE_DURATION=86400000

# ---- Rate Limiting ----
VITE_API_RATE_LIMIT=100
VITE_API_RATE_WINDOW=900000

# ---- Security ----
VITE_ENABLE_CSP=true
VITE_ENABLE_HTTPS_REDIRECT=true
VITE_SECURE_COOKIES=true