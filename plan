         rendererOptions: {
           // Wait for content to load
           renderAfterDocumentEvent: 'render-event',
           // Or wait for specific time
           renderAfterTime: 5000,
           // Viewport
           viewport: {
             width: 1280,
             height: 800
           }
         },

         // Post-processing
         postProcess(renderedRoute) {
           // Clean up scripts/styles if needed
           return renderedRoute;
         }
       })
     ]

