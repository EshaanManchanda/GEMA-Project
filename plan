 6. Font System Implementation

 File: frontend/src/styles/index.css

 Google Fonts Import (add at top):
 @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600;700;800&display=swap');

 Add custom properties:
 :root {
   /* Typography Scale - Using Inter (body) + Playfair Display (headings) */
   --blog-font-body: 'Inter', system-ui, -apple-system, sans-serif;
   --blog-font-heading: 'Playfair Display', Georgia, 'Times New Roman', serif;
   --blog-font-mono: 'JetBrains Mono', 'Fira Code', 'Courier New', monospace;

   /* Font Sizes (responsive with clamp) */
   --blog-text-xs: clamp(0.75rem, 0.7rem + 0.25vw, 0.875rem);
   --blog-text-sm: clamp(0.875rem, 0.8rem + 0.375vw, 1rem);
   --blog-text-base: clamp(1rem, 0.9rem + 0.5vw, 1.125rem);
   --blog-text-lg: clamp(1.125rem, 1rem + 0.625vw, 1.25rem);
   --blog-text-xl: clamp(1.25rem, 1.1rem + 0.75vw, 1.5rem);
   --blog-text-2xl: clamp(1.5rem, 1.3rem + 1vw, 2rem);
   --blog-text-3xl: clamp(2rem, 1.7rem + 1.5vw, 3rem);

   /* Line Heights */
   --blog-leading-tight: 1.25;
   --blog-leading-normal: 1.6;
   --blog-leading-relaxed: 1.75;

   /* Colors (overridable per post) */
   --blog-color-text: #1f2937;
   --blog-color-heading: #111827;
   --blog-color-link: #2563eb;
   --blog-color-accent: var(--primary-500, #8b5cf6);
 }

 /* Per-post override via inline style on .blog-content */
 .blog-content[data-theme="custom"] {
   /* Override with custom properties set via style attribute */
 }

 Usage in BlogDetailPage:
 <div
   className="blog-content"
   data-theme={blog.customTheme ? 'custom' : 'default'}
   style={blog.customTheme ? {
     '--blog-color-text': blog.customTheme.textColor,
     '--blog-color-heading': blog.customTheme.headingColor,
     '--blog-color-link': blog.customTheme.linkColor,
     '--blog-font-body': blog.customTheme.fontBody,
     '--blog-font-heading': blog.customTheme.fontHeading
   } : undefined}
 >

