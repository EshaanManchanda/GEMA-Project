     Phase 5: Combined Rating Calculation

     5.1 Backend - Calculate Combined Rating

     File: backend/src/services/event.service.ts

     Add method to calculate combined rating:
     async updateCombinedRating(eventId: string) {
       const event = await Event.findById(eventId);
       if (!event) return;

       let platformRating = event.averageRating || 0;
       let platformCount = event.reviewCount || 0;
       let googleRating = 0;
       let googleCount = 0;

       if (event.googlePlaceId) {
         const googleData = await googlePlacesService.getPlaceReviews(event.googlePlaceId);
         googleRating = googleData.rating;
         googleCount = googleData.totalRatings;
       }

       // Weighted average
       const totalCount = platformCount + googleCount;
       const combinedRating = totalCount > 0
         ? ((platformRating * platformCount) + (googleRating * googleCount)) / totalCount
         : 0;

       await Event.findByIdAndUpdate(eventId, {
         'stats.combinedRating': combinedRating,
         'stats.combinedReviewCount': totalCount,
         'stats.googleRating': googleRating,
         'stats.googleReviewCount': googleCount,
       });
     }

