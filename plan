     Step 4.4: Add Dynamic Route Pre-rendering Script

     File: frontend/scripts/generate-prerender-routes.js (NEW)

     // Fetch dynamic routes from API and generate route list
     const fs = require('fs');
     const path = require('path');

     async function generateRoutes() {
       const routes = [
         '/',
         '/events',
         '/blog',
         '/vendors',
         '/about',
         '/contact',
       ];

       // Fetch dynamic event routes
       try {
         const eventsResponse = await fetch('https://gema-project.onrender.com/api/events?limit=100&status=published');
         const eventsData = await eventsResponse.json();
         const eventRoutes = eventsData.data.events.map(e => `/events/${e._id}`);
         routes.push(...eventRoutes);
       } catch (err) {
         console.warn('Could not fetch events for pre-rendering');
       }

       // Fetch dynamic blog routes
       try {
         const blogsResponse = await fetch('https://gema-project.onrender.com/api/blogs?limit=100&status=published');
         const blogsData = await blogsResponse.json();
         const blogRoutes = blogsData.data.blogs.map(b => `/blog/${b.slug}`);
         routes.push(...blogRoutes);
       } catch (err) {
         console.warn('Could not fetch blogs for pre-rendering');
       }

       // Write routes to JSON
       fs.writeFileSync(
         path.join(__dirname, '../prerender-routes.json'),
         JSON.stringify(routes, null, 2)
       );

       console.log(`Generated ${routes.length} routes for pre-rendering`);
     }

     generateRoutes();

