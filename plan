     export class GooglePlacesService {
       private cacheTTL = 30 * 24 * 60 * 60; // 30 days

       async getPlaceReviews(placeId: string) {
         const cacheKey = `google:place:${placeId}`;
         const cached = await cacheService.get(cacheKey);
         if (cached) return cached;

         const response = await axios.get(
           'https://maps.googleapis.com/maps/api/place/details/json',
           { params: { place_id: placeId, fields: 'reviews,rating,user_ratings_total', key: apiKey } }
         );

         const data = { reviews: result.reviews || [], rating: result.rating || 0, totalRatings: result.user_ratings_total || 0 };
         await cacheService.set(cacheKey, data, { ttl: cacheTTL });
         return data;
       }
     }

