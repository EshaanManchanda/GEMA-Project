# Server Configuration
PORT=5001
BASE_URL=http://localhost:5001
# BASE_URL=https://api.kidrove.com
# NODE_ENV=production
# MODE=production
NODE_ENV=development
MODE=development
DEBUG_LOGS=true
DEBUG_AUTH=false
DEBUG_CORS=false
# MongoDB Connection
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.XXXXX.mongodb.net/kidrove
# MONGODB_URI=mongodb://127.0.0.1:27017/Kidrove

# MongoDB Connection Options
MONGODB_CONNECT_TIMEOUT_MS=30000
MONGODB_SOCKET_TIMEOUT_MS=45000
MONGODB_SERVER_SELECTION_TIMEOUT_MS=30000
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=2
MONGODB_MAX_IDLE_TIME_MS=30000
MONGODB_RETRY_WRITES=true
MONGODB_RETRY_READS=true

# JWT Configuration
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Admin Registration Secret (for initial admin setup)
ADMIN_SECRET_KEY=

# Firebase Configuration
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_FIREBASE_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-XXXXX@your-project.iam.gserviceaccount.com
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# hostinger Credentials
EMAIL_SERVICE=hostinger
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=587
EMAIL_USERNAME=your_email@yourdomain.com
EMAIL_PASSWORD=your_email_password
EMAIL_FROM=your_email@yourdomain.com
EMAIL_FROM_NAME=Kidrove

# Ethereal test mailbox (development only)
# EMAIL_SERVICE=ethereal
# EMAIL_HOST=smtp.ethereal.email
# EMAIL_PORT=587
# EMAIL_USERNAME=edd.homenick@ethereal.email
# EMAIL_PASSWORD=your_ethereal_password
# EMAIL_FROM=edd.homenick@ethereal.email
# EMAIL_FROM_NAME=Kidrove Test

# Stripe Payment Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_...

# Test Keys (for development fallback)
STRIPE_TEST_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_TEST_SECRET_KEY=sk_test_your_stripe_secret_key

# Payment Environment Configuration
PAYMENT_ENVIRONMENT=test
USE_LIVE_KEYS=false
STRIPE_COMPLIANCE_MODE=uae-standard
PAYMENT_REGION=AE
DEFAULT_CURRENCY=AED
BASE_CURRENCY=AED

# Currency Configuration
EXCHANGE_RATE_API_KEY=
SUPPORTED_CURRENCIES=AED,USD
ENABLE_CURRENCY_AUTO_DETECT=false


# Email Service Configuration (Enhanced)
EMAIL_SERVICE=hostinger
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=587
EMAIL_USERNAME=your_email@yourdomain.com
EMAIL_PASSWORD=your_email_password
EMAIL_FROM=your_email@yourdomain.com
EMAIL_FROM_NAME=Kidrove


# Alternative Email Services (uncomment to use)
# For Gmail SMTP
# EMAIL_SERVICE=gmail
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USERNAME=your_gmail@gmail.com
# EMAIL_PASSWORD=your_app_password

# For SendGrid
# EMAIL_SERVICE=sendgrid
# SENDGRID_API_KEY=your_sendgrid_api_key

# File Upload Configuration
UPLOAD_PROVIDER=local
# UPLOAD_PROVIDER=cloudinary
UPLOAD_PATH=uploads/
MAX_FILE_SIZE=10485760
MAX_IMAGE_SIZE=10485760
MAX_VIDEO_SIZE=524288000
MAX_DOCUMENT_SIZE=20971520
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf,video/mp4,video/webm

CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_UPLOAD_PRESET=ml_default
CLOUDINARY_SECURE=true
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name

# SEO Configuration
SITE_NAME=Kidrove
APP_DOMAIN=kidrove.com
APP_URL=https://kidrove.com
SITE_DESCRIPTION=Discover and book amazing family events and kids activities across the UAE
CONTACT_EMAIL=contact@kidrove.com
SUPPORT_EMAIL=contact@kidrove.com

# Social Media
TWITTER_HANDLE=@kidrove
FACEBOOK_PAGE=kidrove
INSTAGRAM_HANDLE=kidrove

# Default Author Configuration
DEFAULT_AUTHOR_NAME=Kidrove Team
DEFAULT_AUTHOR_EMAIL=contact@kidrove.com
DEFAULT_AUTHOR_AVATAR=https://res.cloudinary.com/dmer8oqdq/image/upload/v1763970345/KidRove-Logo_taua9n.png
DEFAULT_AUTHOR_BIO=The Kidrove team is dedicated to bringing families the best kids activities and events across the UAE.

# Security Configuration
BCRYPT_SALT_ROUNDS=12
PASSWORD_MIN_LENGTH=8
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=1800000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_SKIP_FAILED_REQUESTS=true

# Session Configuration
SESSION_SECRET=your_super_secret_session_key_here
SESSION_MAX_AGE=86400000

# SMTP Configuration (for EmailService optimization)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=your_email@yourdomain.com
SMTP_PASS=your_email_password
SMTP_FROM=your_email@yourdomain.com

# Redis Configuration (for job processing and caching)
REDIS_HOST=your_redis_host
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=your_redis_password
REDIS_TLS=false
REDIS_DB=0
REDIS_QUEUE_DB=0
REDIS_TLS_REJECT_UNAUTHORIZED=true

# Disable Redis for development (set to true to disable Redis completely)
DISABLE_REDIS=true

# Job Processing Configuration
ENABLE_JOBS=true

# Cache Configuration (Redis - Optional)
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=your_redis_password

# Monitoring & Logging
LOG_LEVEL=info
LOG_FILE_PATH=logs/
ENABLE_REQUEST_LOGGING=true

# QR Code Configuration
QR_CODE_SIZE=200
QR_CODE_MARGIN=2
QR_CODE_ERROR_CORRECTION=M

# Ticket Configuration
TICKET_VALIDITY_DAYS=30
TICKET_TRANSFER_ENABLED=true
TICKET_RESEND_COOLDOWN=300000

# Event Configuration
EVENT_APPROVAL_REQUIRED=true
MAX_EVENTS_PER_VENDOR=50
EVENT_IMAGE_MAX_COUNT=10

# Order Configuration
ORDER_EXPIRY_MINUTES=30
REFUND_PROCESSING_FEE_PERCENT=3
MAX_REFUND_PROCESSING_FEE=10

# Review Configuration
REVIEW_AUTO_APPROVAL=false
MAX_REVIEW_FLAGS_BEFORE_HIDE=3
REVIEW_EDIT_TIME_LIMIT=24
# Frontend URL
# Production:
# FRONTEND_URL=https://kidrove.com
# ALLOWED_ORIGINS=https://kidrove.com,https://kidrove.in,https://kidrove.ae,https://www.kidrove.com,https://www.kidrove.in,https://www.kidrove.ae
# ADDITIONAL_ALLOWED_ORIGINS=https://staging.kidrove.com
# Development:
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=
ADDITIONAL_ALLOWED_ORIGINS=

# Google Maps Integration
GOOGLE_PLACES_API_KEY=
GOOGLE_MAPS_API_KEY=

# Google Search Console Integration (admin analytics — organic search stats)
# 1. Google Cloud Console → enable "Search Console API" → create Service Account → download JSON key
# 2. Google Search Console → Settings → Users → add service account email as Owner
# Paste the full service account JSON minified on one line:
GOOGLE_SERVICE_ACCOUNT_JSON=
# Comma-separated list of verified property URLs (e.g. sc-domain:yourdomain.com,sc-domain:yourdomain.ae):
SEARCH_CONSOLE_SITE_URLS=

# AI Chatbot Service (requires KVM2+ with 8GB RAM for 7B model)
CHATBOT_URL=http://localhost:8000

# Web Push VAPID Keys (generate: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:contact@yourdomain.com


# SMS Service Configuration
# Set SMS_PROVIDER to: development (default, logs to console), twilio, aws, or firebase
SMS_PROVIDER=development

# Twilio credentials (required if SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# AWS SNS credentials (required if SMS_PROVIDER=aws)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=


# WhatsApp / Cunnekt Configuration
# Set WHATSAPP_PROVIDER to: dev (default, logs to console) or cunnekt
WHATSAPP_PROVIDER=dev
# Cunnekt exposes two incompatible API generations (doc/CUNNEKT_API_GUIDE.md §1).
# Set to whichever your dashboard's template "API Payload" action actually shows —
# do not guess. legacy = /api/v1/whatsapp/sendtemplate + templateid.
# rest-v1 = /restapi/v1/whatsapp/sendtemplate + template.name.
CUNNEKT_API_VERSION=legacy
CUNNEKT_BASE_URL=https://app.cunnekt.com
CUNNEKT_API_KEY=
# Shared secret embedded as a path segment in the webhook URL registered on
# Cunnekt's API Setting page: /api/webhooks/cunnekt/<this value>
CUNNEKT_WEBHOOK_SECRET=

# Communication (WhatsApp/email-marketing) queue behavior
# When true, forces the dev/mock provider even if real provider keys are set —
# guarantees local/staging can never send a real message.
COMMUNICATION_TEST_MODE=true
COMMUNICATION_QUEUE_ENABLED=true
COMMUNICATION_LOG_RAW_PROVIDER_RESPONSE=false
# WhatsApp number (E.164, e.g. +971501234567) that receives admin_alert
# templates (e.g. partner form submissions). Leave blank to skip those alerts.
ADMIN_ALERT_WHATSAPP_PHONE=
