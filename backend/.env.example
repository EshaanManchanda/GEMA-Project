# Server Configuration
PORT=5000
NODE_ENV=development
# For production on Render, set NODE_ENV=production

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/gema
# For production, use MongoDB Atlas connection string:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/gema?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key
JWT_REFRESH_EXPIRES_IN=30d

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
# For production, set to your frontend domain:
# FRONTEND_URL=https://your-frontend-app.onrender.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=15
RATE_LIMIT_MAX=100

# Stripe Payment Configuration
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=noreply@gema.com

# Optional: Email service alternatives
# For SendGrid:
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USERNAME=apikey
# EMAIL_PASSWORD=your_sendgrid_api_key

# For Mailgun:
# EMAIL_HOST=smtp.mailgun.org
# EMAIL_PORT=587
# EMAIL_USERNAME=your_mailgun_username
# EMAIL_PASSWORD=your_mailgun_password

# Cloudinary Configuration (Media Hosting)
CLOUDINARY_CLOUD_NAME=ditxik56f
CLOUDINARY_API_KEY=678385949912239
CLOUDINARY_API_SECRET=rQUULGU6rPoHmBW6yvQPdDkol2k
CLOUDINARY_URL=cloudinary://678385949912239:rQUULGU6rPoHmBW6yvQPdDkol2k@ditxik56f

# Upload Configuration
UPLOAD_PROVIDER=cloudinary
# Options: 'local' or 'cloudinary'
# For production on Render, use 'cloudinary' (recommended)
CLOUDINARY_UPLOAD_PRESET=ml_default
CLOUDINARY_SECURE=true

# Render Deployment Notes:
# 1. Create a MongoDB Atlas cluster and replace MONGODB_URI
# 2. Set up Firebase project and add service account credentials
# 3. Configure Stripe webhooks for your Render domain
# 4. Set up email service (Gmail App Password or SendGrid)
# 5. Configure Cloudinary for file uploads
# 6. Update FRONTEND_URL to your frontend deployment URL
# 7. Generate secure JWT secrets for production