{
  "name": "gema-backend",
  "version": "1.0.0",
  "description": "Backend API for Gema Event Management Platform with Firebase Authentication",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20.0.0 <26.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "nodemon src/server.ts",
    "dev:worker": "nodemon src/workers/index.ts",
    "build": "npm install && tsc",
    "start": "node dist/server.js",
    "start:worker": "node dist/workers/index.js",
    "start:prod": "NODE_ENV=production node dist/server.js",
    "start:worker:prod": "NODE_ENV=production node dist/workers/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "db:seed": "ts-node src/scripts/seed.ts",
    "db:seed-blogs": "ts-node src/scripts/seedBlogs.ts",
    "db:seed-banners": "ts-node src/scripts/seedBanners.ts",
    "db:seed-categories": "ts-node src/scripts/seedCategories.ts",
    "db:seed-coupons": "ts-node src/scripts/seedCoupons.ts",
    "db:seed-affiliate": "ts-node src/scripts/seedAffiliateVendor.ts",
    "db:seed-seo": "ts-node src/scripts/seedSEOContent.ts",
    "db:seed-faqs": "ts-node src/scripts/seed-faqs.ts",
    "db:seed-production-seo": "ts-node src/scripts/seed-production-seo.ts",
    "db:seed-all": "npm run db:seed && npm run db:seed-blogs && npm run db:seed-categories && npm run db:seed-banners && npm run db:seed-seo && npm run db:seed-faqs",
    "migrate:cloudinary": "ts-node src/scripts/migrate-cloudinary-assets.ts",
    "migrate:blog-images": "ts-node src/scripts/migrate-blog-images.ts",
    "migrate:event-images": "ts-node src/scripts/migrate-event-images.ts",
    "migrate:uuid": "ts-node src/scripts/migrate-add-uuid-to-media.ts",
    "migrate:cloudinary-urls": "ts-node src/scripts/migrate-cloudinary-urls-to-uuid.ts",
    "migrate:brand": "ts-node src/scripts/migrateBrandConfig.ts",
    "migrate:event-slugs": "ts-node src/scripts/generate-event-slugs.ts",
    "script:cleanup-media": "ts-node src/scripts/cleanup-orphaned-media.ts",
    "script:fix-banners": "ts-node src/scripts/fix-banner-assets.ts"
  },
  "dependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/hpp": "^0.2.5",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.17",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^9.0.8",
    "axios": "^1.12.2",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.60.0",
    "cloudinary": "^2.8.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dompurify": "^3.3.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.2.2",
    "firebase-admin": "^13.5.0",
    "googleapis": "^171.4.0",
    "handlebars": "^4.7.8",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.8.0",
    "jsdom": "^26.1.0",
    "jsonwebtoken": "^9.0.2",
    "libphonenumber-js": "^1.12.25",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "ms": "^2.1.3",
    "multer": "^2.0.2",
    "multer-storage-cloudinary": "^4.0.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.11",
    "puppeteer-core": "^24.42.0",
    "qrcode": "^1.5.4",
    "stripe": "^18.4.0",
    "typescript": "^5.3.3",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "overrides": {
    "fast-xml-parser": ">=5.3.8",
    "http-proxy-agent": "^7.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@types/jest": "^29.5.11",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.2.0",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript-eslint": "^8.30.0"
  }
}
